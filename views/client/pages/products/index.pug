extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug


block main
  +alert-success()
  +alert-error()

  .container.my-4.product-list-page
    .row
      .col-12
        .listing-heading
          div
            p.listing-eyebrow Cửa hàng
            h1 Danh sách sản phẩm
          a.btn.btn-outline-primary(href="/cart")
            i.fa-solid.fa-cart-shopping.mr-2
            | Xem giỏ hàng
          

    .row
      each item in products
        .col-12.col-sm-6.col-lg-4.mb-4
          .product-item
            .inner-image
              a(href=`/products/detail/${item.slug}`)
                img(src=item.thumbnail, alt=item.title)
            .inner-content
              h3.inner-title 
                a(href=`/products/detail/${item.slug}`) #{item.title}
              .inner-price-new #{item.priceNew}$
              if(item.discountPercentage)
                .inner-price-old #{item.price}$
              .inner-discount -#{item.discountPercentage}%
              a.product-action(href=`/products/detail/${item.slug}`)
                | Xem chi tiết
                i.fa-solid.fa-arrow-right.ml-2
