extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main
  +alert-success()
  +alert-error()

  .container.my-4.cart-page
    .row
      .col-12
        +box-head("Giỏ hàng")


    if(cartDetail.products.length > 0)
      .row
        .col-12
          .cart-card
            .table-responsive
              table(class="table table-hover cart-table" table-cart)
                thead
                  tr
                    th STT
                    th Sản phẩm
                    th Giá
                    th Số lượng
                    th Tổng tiền
                    th.text-right Hành động
                tbody
                  each item, index in cartDetail.products
                    tr
                      td.text-muted #{index + 1}
                      td
                        .cart-product
                          img(
                            src=item.infoProduct.thumbnail
                            alt=item.infoProduct.title
                          )
                          a(href=`/products/detail/${item.infoProduct.slug}`) #{item.infoProduct.title}
                      td #{item.infoProduct.priceNew}$
                      td
                        input(
                          type="number"
                          name="quantity"
                          value=item.quantity
                          min="1"
                          max=item.infoProduct.stock
                          item-id=item.product_id
                          class="cart-quantity"
                        )
                      td
                        strong #{item.infoProduct.totalPrice}$
                      td.text-right
                        a(
                          href=`/cart/delete/${item.product_id}`
                          class="btn btn-outline-danger btn-sm"
                        )
                          i.fa-regular.fa-trash-can.mr-1
                          | Xóa
            .cart-summary
              div
                span Tổng đơn hàng
                strong #{cartDetail.totalPrice}$
              a(href="/checkout" class="btn btn-success")
                i.fa-solid.fa-credit-card.mr-2
                | Thanh toán
    else
      .empty-cart
        i.fa-solid.fa-bag-shopping
        p Chưa có sản phẩm nào trong giỏ hàng.
        a(href="/products" class="btn btn-primary") Mua sắm ngay
