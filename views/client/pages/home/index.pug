extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main
  +alert-success()
  +alert-error()

  .hero-section.mb-5
    .container
      .row.align-items-center
        .col-md-6.hero-content
          h1.hero-title Khám phá bộ sưu tập sản phẩm mới nhất
          p.hero-desc Trải nghiệm mua sắm tuyệt vời với hàng ngàn ưu đãi hấp dẫn. Chất lượng đỉnh cao, thiết kế thời thượng.
          a.btn.btn-primary.hero-btn(href="/products") Xem bộ sưu tập
        .col-md-6.hero-image
          img.img-fluid(src="https://images.unsplash.com/photo-1483985988355-763728e1935b?q=80&w=1470&auto=format&fit=crop", alt="Hero Banner")

  .container.my-5
    .row
      .col-12
        +box-head("Sản phẩm nổi bật")

    .row
      each item in productsFeatured
        .col-4.mb-3
          .product-item
            .inner-image
              a(href=`/products/detail/${item.slug}`)
                img(src=item.thumbnail, alt=item.title)
            .inner-content
              h3.inner-title 
                a(href=`/products/detail/${item.slug}`) #{item.title}
              .inner-price-new #{item.priceNew}$
              if(item.discountPercentage)
                .inner-price-old #{item.price}$
              .inner-discount -#{item.discountPercentage}%

    .row
      .col-12
        +box-head("Sản phẩm mới")

    .row
      each item in productsNew
        .col-4.mb-3
          .product-item
            .inner-image
              a(href=`/products/detail/${item.slug}`)
                img(src=item.thumbnail, alt=item.title)
            .inner-content
              h3.inner-title 
                a(href=`/products/detail/${item.slug}`) #{item.title}
              .inner-price-new #{item.priceNew}$
              if(item.discountPercentage)
                .inner-price-old #{item.price}$
              .inner-discount -#{item.discountPercentage}%