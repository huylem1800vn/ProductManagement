mixin search (keyword) 
    form(id="form-search")
        .input-group
            input(
            type="text"
            placeholder="Tìm theo tên sản phẩm"
            name="keyword"
            class="form-control"
            value=keyword
            )
            .input-group-append
                button(
                    class="btn btn-primary"
                    type="submit"
                ) 
                    i.fa-solid.fa-magnifying-glass
